<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SPEAKVERSE - Global Explorer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap');
        body { font-family: 'Poppins', sans-serif; background-color: #0f172a; color: white; }
        .glass-panel { background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.1); }
        .tab-content { display: none; }
        .tab-content.active { display: block; }
        .pulse { animation: pulse 2s infinite; }
        @keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.05); } 100% { transform: scale(1); } }
    </style>
</head>
<body class="min-h-screen flex flex-col">

    <nav class="glass-panel sticky top-0 z-50 px-6 py-4 flex justify-between items-center shadow-lg">
        <div class="flex items-center gap-3">
            <i class="fa-solid fa-globe text-blue-400 text-3xl pulse"></i>
            <h1 class="text-2xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-500">
                SPEAKVERSE
            </h1>
        </div>
        <div class="flex items-center gap-6">
            <div class="text-right hidden sm:block">
                <p class="text-sm text-gray-400">Level 5: <span class="text-yellow-400 font-bold">Conversation Master</span></p>
                <div class="w-32 bg-gray-700 rounded-full h-2 mt-1">
                    <div class="bg-yellow-400 h-2 rounded-full" style="width: 75%"></div>
                </div>
                <p class="text-xs text-yellow-400 mt-1">2,450 XP</p>
            </div>
            <img src="https://api.dicebear.com/6.x/avataaars/svg?seed=Explorer" alt="Avatar" class="w-12 h-12 rounded-full border-2 border-blue-400">
        </div>
    </nav>

    <div class="flex flex-1 overflow-hidden">
        
        <aside class="glass-panel w-20 md:w-64 flex flex-col gap-2 p-4 hidden sm:flex">
            <button onclick="switchTab('map')" class="nav-btn w-full flex items-center gap-4 text-left p-3 rounded-lg bg-blue-600 hover:bg-blue-500 transition">
                <i class="fa-solid fa-map-location-dot text-xl"></i> <span class="hidden md:inline font-semibold">Global Map</span>
            </button>
            <button onclick="switchTab('ai')" class="nav-btn w-full flex items-center gap-4 text-left p-3 rounded-lg hover:bg-gray-700 transition">
                <i class="fa-solid fa-robot text-xl"></i> <span class="hidden md:inline font-semibold">AI Trainer</span>
            </button>
            <button onclick="switchTab('arena')" class="nav-btn w-full flex items-center gap-4 text-left p-3 rounded-lg hover:bg-gray-700 transition">
                <i class="fa-solid fa-khanda text-xl"></i> <span class="hidden md:inline font-semibold">Challenge Arena</span>
            </button>
            <button onclick="switchTab('studio')" class="nav-btn w-full flex items-center gap-4 text-left p-3 rounded-lg hover:bg-gray-700 transition">
                <i class="fa-solid fa-video text-xl"></i> <span class="hidden md:inline font-semibold">Creator Studio</span>
            </button>
            <button onclick="switchTab('hub')" class="nav-btn w-full flex items-center gap-4 text-left p-3 rounded-lg hover:bg-gray-700 transition">
                <i class="fa-solid fa-comments text-xl"></i> <span class="hidden md:inline font-semibold">Global Hub</span>
            </button>
        </aside>

        <main class="flex-1 p-6 overflow-y-auto">
            
            <section id="map" class="tab-content active">
                <h2 class="text-3xl font-bold mb-2">🌎 Global Mission Map</h2>
                <p class="text-gray-400 mb-8">Select your destination and complete the mission to unlock new countries!</p>
                
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                    <div class="glass-panel p-6 rounded-xl border-t-4 border-blue-500 cursor-pointer hover:scale-105 transition">
                        <i class="fa-solid fa-flag-usa text-4xl mb-4 text-blue-400"></i>
                        <h3 class="text-xl font-bold">USA</h3>
                        <p class="text-sm text-gray-400 mb-4">Speaking Mission</p>
                        <p class="text-sm mb-4">"Introduce yourself to the world"</p>
                        <button class="w-full bg-blue-500 hover:bg-blue-600 py-2 rounded font-bold">Start Mission</button>
                    </div>
                    <div class="glass-panel p-6 rounded-xl border-t-4 border-red-500 cursor-pointer hover:scale-105 transition">
                        <i class="fa-solid fa-headphones text-4xl mb-4 text-red-400"></i>
                        <h3 class="text-xl font-bold">United Kingdom</h3>
                        <p class="text-sm text-gray-400 mb-4">Listening Mission</p>
                        <p class="text-sm mb-4">"Order food in a restaurant"</p>
                        <button class="w-full bg-red-500 hover:bg-red-600 py-2 rounded font-bold">Start Mission</button>
                    </div>
                    <div class="glass-panel p-6 rounded-xl border-t-4 border-gray-600 opacity-60">
                        <i class="fa-solid fa-lock text-4xl mb-4 text-gray-400"></i>
                        <h3 class="text-xl font-bold">Australia</h3>
                        <p class="text-sm text-gray-400 mb-4">Vocabulary Mission</p>
                        <p class="text-sm mb-4 text-yellow-500">Requires Level 6</p>
                        <button class="w-full bg-gray-600 cursor-not-allowed py-2 rounded font-bold">Locked</button>
                    </div>
                    <div class="glass-panel p-6 rounded-xl border-t-4 border-gray-600 opacity-60">
                        <i class="fa-solid fa-lock text-4xl mb-4 text-gray-400"></i>
                        <h3 class="text-xl font-bold">Japan</h3>
                        <p class="text-sm text-gray-400 mb-4">Culture Communication</p>
                        <p class="text-sm mb-4 text-yellow-500">Requires Level 8</p>
                        <button class="w-full bg-gray-600 cursor-not-allowed py-2 rounded font-bold">Locked</button>
                    </div>
                </div>
            </section>

            <section id="ai" class="tab-content">
                <h2 class="text-3xl font-bold mb-2">🤖 AI Speaking Trainer</h2>
                <p class="text-gray-400 mb-8">Practice your pronunciation. The AI will listen and provide instant feedback.</p>
                
                <div class="glass-panel p-8 rounded-xl max-w-2xl mx-auto text-center">
                    <p class="text-xl mb-6">Read this sentence aloud:</p>
                    <blockquote class="text-2xl font-bold text-blue-300 italic mb-8">
                        "I would like to order a cup of coffee and three slices of cake, please."
                    </blockquote>
                    
                    <button id="recordBtn" onclick="simulateAI()" class="bg-red-500 hover:bg-red-600 text-white rounded-full w-24 h-24 flex items-center justify-center mx-auto mb-6 transition">
                        <i class="fa-solid fa-microphone text-4xl"></i>
                    </button>
                    <p id="recordStatus" class="text-gray-400">Click to start recording</p>

                    <div id="aiFeedback" class="hidden mt-8 p-6 bg-gray-800 rounded-lg border border-gray-600 text-left">
                        <h4 class="text-lg font-bold text-green-400 mb-2">Analysis Complete!</h4>
                        <div class="flex items-center gap-4 mb-4">
                            <div class="text-4xl font-bold text-white">82%</div>
                            <div class="w-full bg-gray-700 rounded-full h-4">
                                <div class="bg-green-500 h-4 rounded-full" style="width: 82%"></div>
                            </div>
                        </div>
                        <p class="mb-2"><i class="fa-solid fa-circle-check text-green-400"></i> Great intonation!</p>
                        <p class="mb-2"><i class="fa-solid fa-circle-exclamation text-yellow-400"></i> Try to improve the sound <strong>/th/</strong> in "three".</p>
                        <button class="mt-4 text-blue-400 underline">Listen to native speaker example</button>
                    </div>
                </div>
            </section>

            <section id="arena" class="tab-content">
                <h2 class="text-3xl font-bold mb-2">⚔️ Challenge Arena</h2>
                <p class="text-gray-400 mb-8">Compete with other explorers and climb the leaderboard!</p>
                
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                    <div class="bg-gradient-to-r from-purple-600 to-indigo-600 p-6 rounded-xl text-center cursor-pointer hover:shadow-lg hover:shadow-purple-500/50 transition">
                        <i class="fa-solid fa-book-open text-3xl mb-2"></i>
                        <h3 class="font-bold text-xl">Vocabulary Battle</h3>
                    </div>
                    <div class="bg-gradient-to-r from-green-600 to-teal-600 p-6 rounded-xl text-center cursor-pointer hover:shadow-lg hover:shadow-green-500/50 transition">
                        <i class="fa-solid fa-spell-check text-3xl mb-2"></i>
                        <h3 class="font-bold text-xl">Grammar Race</h3>
                    </div>
                    <div class="bg-gradient-to-r from-orange-600 to-red-600 p-6 rounded-xl text-center cursor-pointer hover:shadow-lg hover:shadow-orange-500/50 transition">
                        <i class="fa-solid fa-ear-listen text-3xl mb-2"></i>
                        <h3 class="font-bold text-xl">Listening Challenge</h3>
                    </div>
                </div>

                <div class="glass-panel rounded-xl overflow-hidden">
                    <div class="bg-gray-800 p-4 border-b border-gray-700"><h3 class="font-bold text-lg"><i class="fa-solid fa-trophy text-yellow-400"></i> Top Explorers Leaderboard</h3></div>
                    <table class="w-full text-left">
                        <thead><tr class="bg-gray-700 text-gray-300"><th class="p-4">Rank</th><th class="p-4">Student</th><th class="p-4">Level</th><th class="p-4">XP</th></tr></thead>
                        <tbody>
                            <tr class="border-b border-gray-700 bg-gray-800/50">
                                <td class="p-4 text-yellow-400 font-bold">#1</td><td class="p-4 flex items-center gap-3"><img src="https://api.dicebear.com/6.x/avataaars/svg?seed=Alex" class="w-8 h-8 rounded-full"> Alex R.</td><td class="p-4">12 (Global Communicator)</td><td class="p-4">5,200</td>
                            </tr>
                            <tr class="border-b border-gray-700">
                                <td class="p-4 text-gray-300 font-bold">#2</td><td class="p-4 flex items-center gap-3"><img src="https://api.dicebear.com/6.x/avataaars/svg?seed=Budi" class="w-8 h-8 rounded-full"> Budi S.</td><td class="p-4">10 (Expert)</td><td class="p-4">4,150</td>
                            </tr>
                            <tr class="bg-blue-900/30">
                                <td class="p-4 text-orange-400 font-bold">#5</td><td class="p-4 flex items-center gap-3"><img src="https://api.dicebear.com/6.x/avataaars/svg?seed=Explorer" class="w-8 h-8 rounded-full border border-blue-400"> You</td><td class="p-4">5 (Conversation Master)</td><td class="p-4">2,450</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </section>

            <section id="studio" class="tab-content">
                <div class="flex justify-between items-center mb-8">
                    <div>
                        <h2 class="text-3xl font-bold mb-2">🎨 English Creator Studio</h2>
                        <p class="text-gray-400">Publish your projects (Vlogs, Podcasts, Storytelling) to the world!</p>
                    </div>
                    <button class="bg-blue-500 hover:bg-blue-600 px-6 py-3 rounded-lg font-bold shadow-lg"><i class="fa-solid fa-upload"></i> Upload Project</button>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="glass-panel rounded-xl overflow-hidden">
                        <div class="h-40 bg-gray-700 flex items-center justify-center relative">
                            <i class="fa-solid fa-play text-4xl text-white opacity-80 hover:opacity-100 cursor-pointer"></i>
                            <span class="absolute bottom-2 right-2 bg-black/70 px-2 py-1 text-xs rounded">03:45</span>
                        </div>
                        <div class="p-4">
                            <span class="text-xs font-bold text-blue-400 bg-blue-900/50 px-2 py-1 rounded mb-2 inline-block">Vlog Mission</span>
                            <h3 class="font-bold mb-1">My Trip to Bali (English)</h3>
                            <p class="text-sm text-gray-400"><i class="fa-solid fa-heart text-red-500"></i> 124 Likes • By Sarah</p>
                        </div>
                    </div>
                    </div>
            </section>

            <section id="hub" class="tab-content">
                <h2 class="text-3xl font-bold mb-2">💬 Global Communication Hub</h2>
                <p class="text-gray-400 mb-8">Discuss and ask questions with other explorers in English!</p>
                
                <div class="glass-panel rounded-xl p-6">
                    <div class="flex gap-4 mb-6">
                        <img src="https://api.dicebear.com/6.x/avataaars/svg?seed=Explorer" class="w-12 h-12 rounded-full">
                        <div class="flex-1">
                            <textarea class="w-full bg-gray-800 border border-gray-700 rounded-lg p-3 text-white focus:outline-none focus:border-blue-500" rows="3" placeholder="What's on your mind? (Use English please...)"></textarea>
                            <div class="text-right mt-2"><button class="bg-blue-500 hover:bg-blue-600 px-6 py-2 rounded font-bold">Post</button></div>
                        </div>
                    </div>
                    <hr class="border-gray-700 mb-6">
                    <div class="flex gap-4">
                        <img src="https://api.dicebear.com/6.x/avataaars/svg?seed=Teacher" class="w-12 h-12 rounded-full">
                        <div>
                            <h4 class="font-bold">Mr. David <span class="bg-yellow-500 text-black text-xs px-2 py-0.5 rounded ml-2">Teacher</span></h4>
                            <p class="text-sm text-gray-400 mb-2">2 hours ago</p>
                            <p class="mb-3">Hello explorers! Don't forget that Mission 3 requires you to interview a tourist. Share your tips here on how to approach them politely!</p>
                            <div class="flex gap-4 text-sm text-gray-400">
                                <button class="hover:text-white"><i class="fa-solid fa-thumbs-up"></i> 45 Likes</button>
                                <button class="hover:text-white"><i class="fa-solid fa-comment"></i> 12 Replies</button>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

        </main>
    </div>

    <div class="glass-panel flex sm:hidden justify-around p-3 sticky bottom-0 z-50">
        <button onclick="switchTab('map')" class="text-blue-400 flex flex-col items-center"><i class="fa-solid fa-map-location-dot text-xl"></i><span class="text-[10px]">Map</span></button>
        <button onclick="switchTab('ai')" class="text-gray-400 flex flex-col items-center"><i class="fa-solid fa-robot text-xl"></i><span class="text-[10px]">Trainer</span></button>
        <button onclick="switchTab('arena')" class="text-gray-400 flex flex-col items-center"><i class="fa-solid fa-khanda text-xl"></i><span class="text-[10px]">Arena</span></button>
        <button onclick="switchTab('studio')" class="text-gray-400 flex flex-col items-center"><i class="fa-solid fa-video text-xl"></i><span class="text-[10px]">Studio</span></button>
        <button onclick="switchTab('hub')" class="text-gray-400 flex flex-col items-center"><i class="fa-solid fa-comments text-xl"></i><span class="text-[10px]">Hub</span></button>
    </div>

    <script>
        // Tab Switching Logic
        function switchTab(tabId) {
            // Hide all tabs
            document.querySelectorAll('.tab-content').forEach(tab => {
                tab.classList.remove('active');
            });
            // Show selected tab
            document.getElementById(tabId).classList.add('active');
            
            // Update sidebar styles
            document.querySelectorAll('aside .nav-btn').forEach(btn => {
                btn.classList.remove('bg-blue-600');
                btn.classList.add('hover:bg-gray-700');
            });
            event.currentTarget.classList.add('bg-blue-600');
            event.currentTarget.classList.remove('hover:bg-gray-700');
        }

        // AI Simulator Logic
        function simulateAI() {
            const btn = document.getElementById('recordBtn');
            const status = document.getElementById('recordStatus');
            const feedback = document.getElementById('aiFeedback');
            
            // UI Change to "Recording"
            btn.classList.remove('bg-red-500', 'hover:bg-red-600');
            btn.classList.add('bg-gray-500', 'pulse');
            status.innerHTML = '<i class="fa-solid fa-circle text-red-500 pulse"></i> Recording... speak now.';
            feedback.classList.add('hidden');

            // Simulate AI Processing time (3 seconds)
            setTimeout(() => {
                btn.classList.remove('bg-gray-500', 'pulse');
                btn.classList.add('bg-red-500', 'hover:bg-red-600');
                status.innerText = 'Analysis Complete!';
                feedback.classList.remove('hidden');
            }, 3000);
        }
    </script>
</body>
</html>
